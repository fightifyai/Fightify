"""MPMD main Python extension"""

from jaxlib.mlir import ir

def register_dialect(context: jaxlib.ir.Context, load: bool = True) -> None: ...

class UserOriginAttr(jaxlib.ir.Attribute):
    @staticmethod
    def isinstance(other_attribute: jaxlib.ir.Attribute) -> bool: ...

    def __repr__(self) -> str: ...

    @classmethod
    def get(*args, **kwargs):
        """
        get(cls: object, name: str, transpose_count: int, context: jaxlib.ir.Context | None = None) -> object

        Creates a UserOriginAttr with the given user name and transpose count.
        """

    @property
    def user_name(self) -> str: ...

    @property
    def transpose_count(self) -> int: ...
