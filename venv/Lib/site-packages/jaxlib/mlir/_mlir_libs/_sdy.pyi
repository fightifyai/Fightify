class MeshAxisAttr(jaxlib.ir.Attribute):
    @staticmethod
    def isinstance(other_attribute: jaxlib.ir.Attribute) -> bool: ...

    def __repr__(self) -> str: ...

    @classmethod
    def get(*args, **kwargs):
        """
        get(cls: object, name: str, size: int, context: jaxlib.ir.Context | None = None) -> object

        Creates a MeshAxisAttr with the given axis name and size.
        """

    @property
    def name(self) -> str: ...

    @property
    def size(self) -> int: ...

