"""MLIR LLVM Dialect"""

from collections.abc import Sequence

import _mlir

from jaxlib.mlir import ir


class StructType(jaxlib.ir.Type):
    def __init__(self, cast_from_type: jaxlib.ir.Type) -> None: ...

    static_typeid: jaxlib.ir.TypeID = ...
    """(arg: object, /) -> jaxlib.ir.TypeID"""

    @property
    def typeid(self) -> jaxlib.ir.TypeID: ...

    def __repr__(self) -> str: ...

    type_name: str = ...
    """(arg: object, /) -> str"""

    @staticmethod
    def get_literal(elements: Sequence[jaxlib.ir.Type], *, packed: bool = False, loc: _ir.Location | None = None, context: _ir.Context | None = None) -> StructType: ...

    @staticmethod
    def get_literal_unchecked(elements: Sequence[jaxlib.ir.Type], *, packed: bool = False, context: _ir.Context | None = None) -> StructType: ...

    @staticmethod
    def get_identified(name: str, *, context: _ir.Context | None = None) -> StructType: ...

    @staticmethod
    def get_opaque(name: str, context: _ir.Context | None = None) -> StructType: ...

    def set_body(self, elements: Sequence[jaxlib.ir.Type], *, packed: bool = False) -> None: ...

    @staticmethod
    def new_identified(name: str, elements: Sequence[jaxlib.ir.Type], *, packed: bool = False, context: _ir.Context | None = None) -> StructType: ...

    @property
    def name(self) -> str | None: ...

    @property
    def body(self) -> object: ...

    @property
    def packed(self) -> bool: ...

    @property
    def opaque(self) -> bool: ...

class PointerType(jaxlib.ir.Type):
    def __init__(self, cast_from_type: jaxlib.ir.Type) -> None: ...

    static_typeid: jaxlib.ir.TypeID = ...
    """(arg: object, /) -> jaxlib.ir.TypeID"""

    @property
    def typeid(self) -> jaxlib.ir.TypeID: ...

    def __repr__(self) -> str: ...

    type_name: str = ...
    """(arg: object, /) -> str"""

    @staticmethod
    def get(address_space: int | None = None, *, context: _ir.Context | None = None) -> PointerType: ...

    @property
    def address_space(self) -> int: ...

def translate_module_to_llvmir(module: jaxlib.ir.Operation) -> str: ...
